# ERA Agents Ops — Environment Variable Schema
# This file is SAFE to commit. It contains schema definitions, NOT secret values.
# Inspired by Varlock (https://varlock.dev) pattern from Syntax podcast.
#
# Usage:
#   1. Copy this to your project as .env.schema
#   2. Customize for your project's requirements
#   3. Commit .env.schema to version control
#   4. Create .env (gitignored) with actual values
#   5. Validate at startup using your framework's env validation

## @type {string}
## @required
## @description Primary AI provider API key for Fabric patterns and agent workflows
## @rotate-url https://console.anthropic.com/settings/keys
## @sensitivity CRITICAL
ANTHROPIC_API_KEY=

## @type {string}
## @required
## @description Google Gemini API key for default model routing
## @rotate-url https://aistudio.google.com/apikey
## @sensitivity CRITICAL
GEMINI_API_KEY=

## @type {string}
## @optional
## @description OpenRouter API key for free/paid model access
## @rotate-url https://openrouter.ai/keys
## @sensitivity HIGH
OPENROUTER_API_KEY=

## @type {url}
## @required
## @default http://localhost:11434
## @description Ollama local model server URL
## @sensitivity NONE
OLLAMA_API_URL=http://localhost:11434

## @type {string}
## @optional
## @description Ollama API key (empty for local)
## @sensitivity LOW
OLLAMA_API_KEY=

## @type {string}
## @required
## @default gemini-2.5-flash
## @description Default AI model for Fabric patterns
## @sensitivity NONE
DEFAULT_MODEL=gemini-2.5-flash

## @type {string}
## @required
## @default Gemini
## @description Default AI vendor for Fabric patterns
## @allowed [Ollama, Gemini, Anthropic, OpenRouter]
## @sensitivity NONE
DEFAULT_VENDOR=Gemini

## @type {url}
## @optional
## @description Database connection URL (if applicable)
## @sensitivity CRITICAL
DATABASE_URL=

## @type {string}
## @optional
## @description GitHub personal access token for gh CLI and API access
## @rotate-url https://github.com/settings/tokens
## @sensitivity CRITICAL
GITHUB_TOKEN=

## @type {integer}
## @optional
## @default 3000
## @description Application server port
## @sensitivity NONE
PORT=3000

## @type {string}
## @required
## @default development
## @allowed [development, staging, production]
## @description Application environment
## @sensitivity NONE
NODE_ENV=development
